---
const products = [
  {
    name: "Lithium Battery",
    description: "Reliable replacement battery packs built for everyday electric scooter riding.",
    image: "/images/battery.svg",
    alt: "Electric scooter lithium battery illustration",
  },
  {
    name: "Scooter Alarm",
    description: "A compact alarm upgrade that adds a practical extra layer of protection.",
    image: "/images/alarm.svg",
    alt: "Electric scooter alarm illustration",
  },
  {
    name: "JOYOR Steering Damper",
    description: "JOYOR-compatible damping support for a steadier and more confident ride.",
    image: "/images/damper.svg",
    alt: "JOYOR compatible steering damper illustration",
  },
  {
    name: "Speed Unlock Kit",
    description: "A dedicated kit for compatible scooters. Please ride responsibly and follow local rules.",
    image: "/images/speed-kit.svg",
    alt: "Electric scooter speed unlock kit illustration",
  },
];

const stores = [
  {
    name: "JOFEN SCOOTER",
    href: "https://jofenscooter.com",
    description: "Scooter parts, upgrades and accessories.",
  },
  {
    name: "JOYOR PRIME",
    href: "https://joyorprime.com",
    description: "Explore more JOYOR-compatible solutions.",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Scooter.work supplies electric scooter lithium batteries, alarms, JOYOR-compatible steering dampers and speed unlock kits."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Scooter.work — Electric Scooter Parts</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Scooter.work home">
        <span class="brand-mark">S</span>
        <span>SCOOTER<span>.WORK</span></span>
      </a>
      <nav aria-label="Primary navigation">
        <a href="#products">Products</a>
        <a href="#stores">Stores</a>
        <a class="nav-button" href="#stores">Explore stores <span>↗</span></a>
      </nav>
    </header>

    <main>
      <section class="hero shell">
        <div class="hero-copy">
          <h1>Parts that keep your scooter <em>moving.</em></h1>
          <p class="hero-text">
            Practical parts and upgrades for electric scooters — selected for dependable power,
            better control and a safer everyday ride.
          </p>
          <div class="hero-actions">
            <a class="button button-primary" href="#products">Browse products <span>↓</span></a>
            <a class="text-link" href="#stores">Visit our stores <span>↗</span></a>
          </div>
        </div>
        <div class="hero-visual">
          <img src="/images/hero-scooter.svg" alt="Electric scooter illustration" />
        </div>
      </section>

      <section class="intro shell">
        <div>
          <h2>Focused essentials.<br /><span>Nothing unnecessary.</span></h2>
          <p>
            Scooter.work is a straightforward product guide for riders looking for useful electric
            scooter parts. Choose a product category, then continue to one of our stores.
          </p>
        </div>
      </section>

      <section class="products shell" id="products">
        {products.map((product) => (
          <article class="product-card">
            <div class="product-image">
              <img src={product.image} alt={product.alt} />
            </div>
            <div class="product-copy">
              <h3>{product.name}</h3>
              <span>{product.description}</span>
            </div>
          </article>
        ))}
      </section>

      <section class="stores" id="stores">
        <div class="shell">
          <h2>Choose your store.</h2>
          <div class="store-grid">
            {stores.map((store) => (
              <a class="store-card" href={store.href} target="_blank" rel="noreferrer">
                <h3>{store.name}</h3>
                <p>{store.description}</p>
                <strong>Visit store <b>↗</b></strong>
              </a>
            ))}
          </div>
        </div>
      </section>
    </main>

    <footer class="shell">
      <a class="brand" href="/" aria-label="Scooter.work home">
        <span class="brand-mark">S</span>
        <span>SCOOTER<span>.WORK</span></span>
      </a>
      <p>Electric scooter parts & accessories.</p>
      <a class="support-email" href="mailto:support@scooter.work">support@scooter.work</a>
      <small>© {new Date().getFullYear()} SCOOTER.WORK</small>
    </footer>
  </body>
</html>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@400;500;600;700&display=swap");

  :root {
    color-scheme: dark;
    --bg: #111515;
    --panel: #1a2020;
    --line: rgba(238, 244, 232, 0.14);
    --text: #edf2e8;
    --muted: #9ca7a2;
    --acid: #dfff48;
    --dark: #101414;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: "Inter", Arial, sans-serif;
  }
  a { color: inherit; text-decoration: none; }
  .shell { width: min(1380px, calc(100% - 48px)); margin-inline: auto; }
  .site-header {
    width: min(1380px, calc(100% - 48px));
    min-height: 78px;
    margin: auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--line);
  }
  .brand { display: flex; align-items: center; gap: 10px; font-size: 15px; font-weight: 800; letter-spacing: 2px; }
  .brand span span { color: var(--acid); }
  .brand-mark { display: grid; width: 32px; height: 32px; place-items: center; background: var(--acid); color: var(--dark); font-size: 17px; letter-spacing: 0; }
  nav { display: flex; align-items: center; gap: 30px; font-size: 13px; font-weight: 700; }
  nav > a:hover, .text-link:hover { color: var(--acid); }
  .nav-button { padding: 12px 16px; border: 1px solid var(--line); }
  .nav-button span { color: var(--acid); }
  .hero { display: grid; min-height: 695px; grid-template-columns: 1.02fr 0.98fr; align-items: center; gap: 52px; }
  h1, h2, h3 { margin: 0; }
  h1, h2 { font-family: "Archivo Black", Impact, sans-serif; font-weight: 400; text-transform: uppercase; }
  h1 { max-width: 720px; margin-top: 22px; font-size: clamp(57px, 6.3vw, 92px); line-height: 0.96; letter-spacing: -4px; }
  h1 em { color: var(--acid); font-style: normal; }
  .hero-text { max-width: 620px; margin: 28px 0 0; color: var(--muted); font-size: 16px; line-height: 1.8; }
  .hero-actions { display: flex; align-items: center; gap: 28px; margin-top: 35px; }
  .button { display: inline-flex; align-items: center; gap: 20px; padding: 16px 18px; color: var(--dark); background: var(--acid); font-size: 13px; font-weight: 800; }
  .button:hover { background: #efffa1; }
  .text-link { font-size: 13px; font-weight: 800; }
  .text-link span { color: var(--acid); }
  .hero-visual img { display: block; width: 100%; }
  .intro { padding: 115px 0 50px; border-top: 1px solid var(--line); }
  h2 { font-size: clamp(39px, 5vw, 67px); line-height: 1; letter-spacing: -2px; }
  h2 span { color: var(--acid); }
  .intro div p { max-width: 720px; margin-top: 22px; color: var(--muted); font-size: 16px; line-height: 1.8; }
  .products { display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px; padding-bottom: 125px; }
  .product-card { overflow: hidden; background: var(--panel); border: 1px solid var(--line); transition: border-color 180ms ease; }
  .product-card:hover { border-color: rgba(223, 255, 72, 0.45); }
  .product-image { overflow: hidden; }
  .product-image img { display: block; width: 100%; }
  .product-copy { padding: 24px; }
  h3 { font-size: 22px; letter-spacing: -0.7px; }
  .product-copy > span { display: block; margin-top: 12px; color: var(--muted); font-size: 14px; line-height: 1.7; }
  .stores { padding: 112px 0 125px; background: #e6ebdf; color: var(--dark); }
  .stores h2 { margin: 0 0 38px; }
  .store-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px; }
  .store-card { padding: 34px; background: #f5f7f0; border: 1px solid rgba(16, 20, 20, 0.12); transition: background 180ms ease; }
  .store-card:hover { background: var(--acid); }
  .store-card h3 { font-family: "Archivo Black"; font-size: clamp(24px, 3vw, 40px); font-weight: 400; }
  .store-card p { min-height: 48px; color: #67706c; font-size: 14px; line-height: 1.7; }
  .store-card strong { display: block; margin-top: 28px; font-size: 13px; text-transform: uppercase; letter-spacing: 1px; }
  .store-card b { float: right; font-size: 18px; }
  footer { display: grid; grid-template-columns: 1fr auto auto auto; gap: 28px; align-items: center; min-height: 114px; }
  footer p, footer small, .support-email { color: var(--muted); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; }
  .support-email:hover { color: var(--acid); }
  @media (max-width: 820px) {
    .shell, .site-header { width: min(100% - 30px, 680px); }
    nav > a:not(.nav-button) { display: none; }
    .hero { display: flex; min-height: auto; flex-direction: column; align-items: stretch; gap: 42px; padding: 76px 0 82px; }
    h1 { font-size: clamp(55px, 15vw, 86px); }
    .hero-visual { margin-inline: auto; }
    .intro { padding: 88px 0 35px; }
    .products { grid-template-columns: 1fr; padding-bottom: 88px; }
    .stores { padding: 82px 0; }
    .store-grid { grid-template-columns: 1fr; }
    footer { display: flex; min-height: auto; flex-wrap: wrap; gap: 6px 20px; padding: 28px 0; }
    footer .brand { width: 100%; margin-bottom: 8px; }
    footer p, footer small { margin: 0; }
  }
</style>
