---
const effectiveDate = "June 2, 2026";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Privacy policy for scooter.work. This informational website does not collect personal information."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Privacy Policy — Scooter.work</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Scooter.work home">
        <span>SCOOTER<span>.WORK</span></span>
      </a>
      <a class="back-link" href="/">Back to home</a>
    </header>

    <main class="shell">
      <section class="privacy">
        <h1>Privacy <em>Policy.</em></h1>
        <p class="effective-date">Effective date: {effectiveDate}</p>

        <div class="policy-grid">
          <section>
            <h2>Overview</h2>
            <p>
              Scooter.work is a static informational website. We do not collect, store or sell
              personal information through this website.
            </p>
          </section>

          <section>
            <h2>No tracking</h2>
            <p>
              We do not use analytics tools, advertising trackers, account registration, contact
              forms or cookies for tracking purposes.
            </p>
          </section>

          <section>
            <h2>External stores</h2>
            <p>
              This website contains links to external stores, including jofenscooter.com and
              joyorprime.com. When you visit another website, its own privacy policy applies.
            </p>
          </section>

          <section>
            <h2>Contact</h2>
            <p>
              If you have a question about this policy, email
              <a href="mailto:support@scooter.work">support@scooter.work</a>.
            </p>
          </section>
        </div>
      </section>
    </main>

    <footer class="shell">
      <a class="brand" href="/" aria-label="Scooter.work home">
        <span>SCOOTER<span>.WORK</span></span>
      </a>
      <small>© {new Date().getFullYear()} SCOOTER.WORK</small>
    </footer>
  </body>
</html>

<style>
  :root {
    color-scheme: dark;
    --bg: #111515;
    --panel: #1a2020;
    --line: rgba(238, 244, 232, 0.14);
    --text: #edf2e8;
    --muted: #9ca7a2;
    --acid: #ff7a1a;
  }

  * { box-sizing: border-box; }
  body { margin: 0; background: var(--bg); color: var(--text); font-family: Arial, sans-serif; }
  a { color: inherit; text-decoration: none; }
  .shell, .site-header { width: min(1380px, calc(100% - 48px)); margin-inline: auto; }
  .site-header { display: flex; min-height: 78px; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--line); }
  .brand { font-size: 15px; font-weight: 800; letter-spacing: 2px; }
  .brand span span { color: var(--acid); }
  .back-link { color: var(--muted); font-size: 12px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; }
  .back-link:hover, .policy-grid a:hover { color: var(--acid); }
  .privacy { padding: 112px 0 126px; }
  h1, h2, p { margin: 0; }
  h1 { font-family: Impact, "Arial Black", sans-serif; font-size: clamp(64px, 9vw, 126px); font-weight: 400; letter-spacing: -3px; line-height: 0.94; text-transform: uppercase; }
  h1 em { color: var(--acid); font-style: normal; }
  .effective-date { margin-top: 24px; color: var(--muted); font-size: 13px; letter-spacing: 1px; text-transform: uppercase; }
  .policy-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; margin-top: 74px; background: var(--line); border: 1px solid var(--line); }
  .policy-grid section { min-height: 220px; padding: 30px; background: var(--panel); }
  h2 { color: var(--acid); font-size: 18px; letter-spacing: 0.5px; text-transform: uppercase; }
  .policy-grid p { max-width: 640px; margin-top: 18px; color: var(--muted); font-size: 15px; line-height: 1.8; }
  .policy-grid a { color: var(--text); }
  footer { display: flex; min-height: 114px; align-items: center; justify-content: space-between; border-top: 1px solid var(--line); }
  footer small { color: var(--muted); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; }
  @media (max-width: 820px) {
    .shell, .site-header { width: min(100% - 30px, 680px); }
    .privacy { padding: 82px 0; }
    .policy-grid { grid-template-columns: 1fr; margin-top: 52px; }
    .policy-grid section { min-height: auto; padding: 24px; }
  }
</style>
